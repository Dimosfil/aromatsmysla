# Copy this file to .env before starting Docker. Never commit real secrets.

HOST_PORT=3000

API_HOST=0.0.0.0
API_PORT=3000
APP_ENV=production
LOG_LEVEL=info

TELEGRAM_POLLING_ENABLED=true
TELEGRAM_BOT_TOKEN=replace-with-real-token

GUIDE_BOT_REQUIRED_CHANNEL_ID=@aromatsmysla
GUIDE_BOT_REQUIRED_CHANNEL_URL=https://t.me/aromatsmysla
GUIDE_BOT_SELECTION_PHOTO_PATH=/app/bot/assets/second-screen-photo.jpg

GUIDE_BOT_GUIDE_1_ID=aroma_vanna
GUIDE_BOT_GUIDE_1_TITLE=AromaVanna guide
GUIDE_BOT_GUIDE_1_BUTTON_PREFIX=Bath
GUIDE_BOT_GUIDE_1_FILE_PATH=/app/bot/guides/aroma-vanna-guide.pdf

GUIDE_BOT_GUIDE_2_ID=essential_oils_women_state
GUIDE_BOT_GUIDE_2_TITLE=7 essential oils for women's state
GUIDE_BOT_GUIDE_2_BUTTON_PREFIX=Oil
GUIDE_BOT_GUIDE_2_FILE_PATH=/app/bot/guides/7-essential-oils-women-state.pdf

SQLITE_INDEX_PATH=/app/data/index.sqlite3
SQLITE_SESSION_PATH=/app/data/sessions.sqlite3

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_WEB_DIR=/app/apps/web/dist
GUIDE_BOT_CONTENT_PATH=/app/data/guide-bot-content.json
GUIDE_BOT_UPLOAD_DIR=/app/data/uploads

AI_PROVIDER=disabled
AI_API_KEY=
