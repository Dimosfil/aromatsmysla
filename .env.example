# Copy this file to .env.local and fill the real Telegram token.
# Bot copy, channel URL, guide titles, button prefixes, media, and uploaded
# files live in GUIDE_BOT_CONTENT_PATH, with content.seed.json used only for
# the first start before admin edits exist.

API_HOST=127.0.0.1
API_PORT=3000
APP_ENV=local
LOG_LEVEL=info

TELEGRAM_POLLING_ENABLED=true
TELEGRAM_BOT_TOKEN=replace-with-token

GUIDE_BOT_REQUIRED_CHANNEL_ID=@aromatsmysla

SQLITE_INDEX_PATH=storage/index.sqlite3
SQLITE_SESSION_PATH=data/sessions.sqlite3
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_WEB_DIR=standalone/apps/web/dist
GUIDE_BOT_CONTENT_PATH=data/guide-bot-content.json
GUIDE_BOT_CONTENT_SEED_PATH=standalone/bot/content.seed.json
GUIDE_BOT_UPLOAD_DIR=data/uploads

AI_PROVIDER=disabled
AI_API_KEY=
