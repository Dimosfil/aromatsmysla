# BotHost-style deployment variables. Never commit real secrets.
# Use this file only if the standalone folder is published as the repository root.
#
# In the hosting form:
# - Bot Token: paste the real Telegram token there.
# - Do not commit a real TELEGRAM_BOT_TOKEN value. The app also accepts
#   BotHost-provided BOT_TOKEN/BOT_API_TOKEN/API_TOKEN as fallbacks.
# - Use polling for this project. Do not rely on BotHost's webhook URL.

API_HOST=0.0.0.0
API_PORT=3000
PORT=3000
APP_ENV=production
LOG_LEVEL=info

TELEGRAM_POLLING_ENABLED=true

GUIDE_BOT_REQUIRED_CHANNEL_ID=@aromatsmysla
GUIDE_BOT_REQUIRED_CHANNEL_URL=https://t.me/aromatsmysla

SQLITE_INDEX_PATH=/app/data/index.sqlite3
SQLITE_SESSION_PATH=/app/data/sessions.sqlite3

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_WEB_DIR=/app/apps/web/dist
GUIDE_BOT_CONTENT_PATH=/app/data/guide-bot-content.json
GUIDE_BOT_CONTENT_SEED_PATH=/app/bot/content.seed.json
GUIDE_BOT_UPLOAD_DIR=/app/data/uploads

AI_PROVIDER=disabled
AI_API_KEY=
